{
  "name": "repotracker",
  "version": "1.0.2",
  "description": "Intelligent local Git repository manager with AI-powered commit messages, health scoring, visual branch management, and an integrated terminal.",
  "author": "Vinzone",
  "license": "MIT",
  "homepage": "https://github.com/Vinit080/repotracker#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vinit080/repotracker.git"
  },
  "keywords": [
    "git",
    "repository",
    "developer-tools",
    "dashboard",
    "ai",
    "terminal",
    "productivity",
    "devtools"
  ],
  "private": true,
  "type": "module",
  "main": "src/main.js",
  "bin": "src/server.js",
  "pkg": {
    "assets": [
      "public/**/*"
    ]
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "team": "cross-env REPOTRACKER_TEAM=1 node src/server.js",
    "start:electron": "electron .",
    "build": "node scripts/build.js",
    "build:electron": "electron-builder",
    "docker:build": "docker build -t repotracker .",
    "docker:up": "docker compose up -d",
    "postinstall": "node src/setup-vendor.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "electron-log": "^5.0.1",
    "electron-updater": "^6.1.8",
    "ws": "^8.21.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "caxa": "^3.0.1",
    "cross-env": "^7.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.0"
  },
  "build": {
    "appId": "com.repotracker.app",
    "productName": "RepoTracker",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "public/logo.png"
    },
    "win": {
      "target": "nsis",
      "icon": "public/logo.png"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development",
      "icon": "public/logo.png"
    },
    "publish": [
      "github"
    ],
    "files": [
      "src/**/*",
      "public/**/*",
      "package.json"
    ]
  }
}
