{
  "name": "repotracker",
  "version": "0.2.0",
  "description": "Intelligent local Git repository manager with AI-powered commit messages, health scoring, visual branch management, and an integrated terminal.",
  "author": "Vinzone",
  "license": "MIT",
  "homepage": "https://github.com/Vinit080/repotracker#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vinit080/repotracker.git"
  },
  "keywords": [
    "git",
    "repository",
    "developer-tools",
    "dashboard",
    "ai",
    "terminal",
    "productivity",
    "devtools"
  ],
  "private": true,
  "type": "module",
  "bin": "src/server.js",
  "pkg": {
    "assets": [
      "public/**/*"
    ]
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "team": "cross-env REPOTRACKER_TEAM=1 node src/server.js",
    "build": "node scripts/build.js",
    "docker:build": "docker build -t repotracker .",
    "docker:up": "docker compose up -d",
    "postinstall": "node src/setup-vendor.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "ws": "^8.21.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "caxa": "^3.0.1",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.0",
    "pkg": "^5.8.1"
  }
}
