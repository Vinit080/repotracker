# ══════════════════════════════════════════════════════════════════════════════
# RepoTracker — Environment Configuration Template (.env.example)
#
# Copy this file to .env and fill in your actual values.
# .env is gitignored — this .env.example IS committed (no real secrets here).
# ══════════════════════════════════════════════════════════════════════════════


# ── Server ────────────────────────────────────────────────────────────────────

# Port the server listens on (default: 4177)
PORT=4177

# Set to 1 to enable Team Mode — binds to 0.0.0.0 so LAN teammates can connect.
# Leave blank for solo mode (localhost only, safer).
REPOTRACKER_TEAM=


# ── LemonSqueezy (License Validation) ─────────────────────────────────────────
#
# Required for real license key validation.
# Without these, the app falls back to offline format-only validation
# and only accepts RT-PRO-XXXX / RT-TEAM-XXXX format keys.
#
# 1. API Key → https://app.lemonsqueezy.com/settings/api  → "New API key"
# 2. Store ID → https://app.lemonsqueezy.com/stores → click your store → ID in the URL
# 3. Product IDs → Products → click each product → ID in the URL

LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key_here
LEMONSQUEEZY_STORE_ID=12345
LEMONSQUEEZY_PRO_PRODUCT_ID=11111
LEMONSQUEEZY_TEAM_PRODUCT_ID=22222


# ── Anonymous Install Ping (Cloudflare Worker) ────────────────────────────────
#
# URL for the opt-in install counter Cloudflare Worker.
# Only pinged once per installation if the user opts in during onboarding.
# Replace with your own deployed worker URL.

PING_URL=https://your-worker.your-subdomain.workers.dev/count
